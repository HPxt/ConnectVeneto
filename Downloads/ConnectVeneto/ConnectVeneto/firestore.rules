rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ---- Helper: Super Admin ----
    function isSuperAdmin() {
      return request.auth != null &&
         request.auth.token.email in [
           'henrique.peixoto@3ainvestimentos.com.br',
           'matheus@3ainvestimentos.com.br',
           'desenvolvedor@3ariva.com.br',
           'dalcion.franco@3ainvestimentos.com.br',
           'ti@3ariva.com.br',
           'lucas.nogueira@3ainvestimentos.com.br'
         ];
    }

    // ---- Helper: Normalizar Email ----
    function normalizeEmail(email) {
      let parts = email.split('@');
      return parts.size() == 2 && parts[1] == '3ariva.com.br' ?
             parts[0] + '@3ainvestimentos.com.br' :
             email;
    }

    // ---- Helper: o usuário está mexendo no próprio registro?
    function isSelf() {
      return request.auth != null &&
             (request.resource.data.authUid == request.auth.uid ||
              normalizeEmail(request.auth.token.email) == normalizeEmail(resource.data.email)
      );
    }

    // ---- Helper: Pode aprovar/reprovar ESTA solicitação ----
    // Regras do novo fluxo:
    // - super admin sempre pode
    // - responsável específico pode apenas quando responsibleUid == auth.uid
    function canApproveThisRequest() {
      return request.auth != null &&
        (
          isSuperAdmin() ||
          (
            resource.data.responsibleUid is string &&
            resource.data.responsibleUid != "" &&
            resource.data.responsibleUid == request.auth.uid
          )
        );
    }

    // =========================
    // systemSettings
    // =========================
    match /systemSettings/{docId} {
      allow read: if docId == 'public_config';
      allow write: if docId == 'public_config' && isSuperAdmin();

      allow read: if docId == 'config';
      allow write: if docId == 'config' && isSuperAdmin();

      allow read: if docId == 'admin_config' && request.auth != null;
      allow write: if docId == 'admin_config' && false;

      allow read: if docId == 'keys' && request.auth != null;
      allow write: if docId == 'keys' && request.auth != null;
    }

    // =========================
    // collaborators
    // =========================
    match /collaborators/{userId} {
      allow read: if request.auth != null;

      allow create: if isSelf() || isSuperAdmin();

      allow update: if isSuperAdmin() ||
      (request.auth.uid == resource.data.authUid) ||
      normalizeEmail(request.auth.token.email) == normalizeEmail(resource.data.email);

      allow delete: if isSuperAdmin();
    }

    // =========================
    // collaborator_logs
    // =========================
    match /collaborator_logs/{logId} {
      allow read: if isSuperAdmin();
      allow create: if request.auth != null;
      allow update, delete: if isSuperAdmin();
    }

    // =========================
    // contacts
    // =========================
    match /contacts/{document=**} {
      allow read: if request.auth != null;
      allow write: if isSuperAdmin();
    }

    // =========================
    // Conteúdo geral
    // =========================
    match /newsItems/{document=**} {
      allow read: if request.auth != null;
      allow write: if isSuperAdmin();
    }

    match /documents/{document=**} {
      allow read: if request.auth != null;
      allow write: if isSuperAdmin();
    }

    match /labs/{document=**} {
      allow read: if request.auth != null;
      allow write: if isSuperAdmin();
    }

    match /messages/{document=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /quickLinks/{document=**} {
      allow read: if request.auth != null;
      allow write: if isSuperAdmin();
    }

    match /rankings/{document=**} {
      allow read: if request.auth != null;
      allow write: if isSuperAdmin();
    }

    match /birthdays/{document=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /leaderTrips/{document=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // =========================
    // vacations
    // =========================
    match /vacations/{vacationId} {
      // Leitura: super admin vê tudo; usuário comum vê só as próprias
      allow read: if request.auth != null
                  && (
                    isSuperAdmin()
                    || resource.data.collaboratorUid == request.auth.uid
                  );

      // Cria:
      // - próprio usuário (fluxo manual)
      // - super admin
      // - responsável designado via sourceRequestId (fluxo de aprovação)
      allow create: if request.auth != null
                    && request.resource.data.collaboratorName is string
                    && request.resource.data.startDate is string
                    && request.resource.data.endDate is string
                    && request.resource.data.businessDays is int
                    && request.resource.data.businessDays > 0
                    && request.resource.data.createdAt is string
                    && request.resource.data.updatedAt is string
                    && (
                      request.resource.data.collaboratorUid == request.auth.uid
                      || isSuperAdmin()
                      || (
                        request.resource.data.sourceRequestId is string
                        && exists(/databases/$(database)/documents/vacation_requests/$(request.resource.data.sourceRequestId))
                        && get(/databases/$(database)/documents/vacation_requests/$(request.resource.data.sourceRequestId)).data.requesterUid == request.resource.data.collaboratorUid
                        && get(/databases/$(database)/documents/vacation_requests/$(request.resource.data.sourceRequestId)).data.responsibleUid == request.auth.uid
                      )
                    );

      // Atualiza/Exclui: somente super admin
      allow update, delete: if request.auth != null && isSuperAdmin();
    }

    // =========================
    // vacation_approvers
    // =========================
    // Document ID = UID do colaborador solicitante
    // Campos esperados: userUid, userName, responsibleUid, responsibleName, ...
    match /vacation_approvers/{collabUid} {
      allow read: if request.auth != null;
      allow write: if isSuperAdmin();
    }

    // =========================
    // vacation_requests
    // =========================
    match /vacation_requests/{requestId} {
      // Leitura:
      // - próprio solicitante
      // - responsável designado desta solicitação
      // - super admin
      allow read: if request.auth != null
                  && (
                    resource.data.requesterUid == request.auth.uid
                    || (
                      resource.data.responsibleUid is string
                      && resource.data.responsibleUid != ""
                      && resource.data.responsibleUid == request.auth.uid
                    )
                    || isSuperAdmin()
                  );

      // Criação: autenticado, somente para si mesmo, sempre pending
      allow create: if request.auth != null
                    && request.resource.data.requesterUid == request.auth.uid
                    && request.resource.data.status == 'pending'
                    && request.resource.data.requesterName is string
                    && request.resource.data.startDate is string
                    && request.resource.data.endDate is string
                    && request.resource.data.businessDays is int
                    && request.resource.data.businessDays > 0
                    && request.resource.data.createdAt is string
                    && request.resource.data.updatedAt is string
                    && (
                      !('responsibleUid' in request.resource.data)
                      || request.resource.data.responsibleUid is string
                    )
                    && (
                      !('responsibleName' in request.resource.data)
                      || request.resource.data.responsibleName is string
                    );

      // Atualização A: aprovação/reprovação por responsável designado ou super admin
      allow update: if request.auth != null
                    && canApproveThisRequest()
                    && resource.data.status == 'pending'
                    && request.resource.data.status in ['approved', 'rejected']
                    && request.resource.data.requesterUid == resource.data.requesterUid
                    && request.resource.data.requesterName == resource.data.requesterName
                    && request.resource.data.startDate == resource.data.startDate
                    && request.resource.data.endDate == resource.data.endDate
                    && request.resource.data.businessDays == resource.data.businessDays
                    && request.resource.data.createdAt == resource.data.createdAt
                    && request.resource.data.reviewedByUid is string
                    && request.resource.data.reviewedByName is string
                    && request.resource.data.reviewedAt is string
                    && request.resource.data.updatedAt is string
                    && (
                      !('requesterArchivedAt' in request.resource.data)
                      || request.resource.data.requesterArchivedAt == resource.data.requesterArchivedAt
                    )
                    && (
                      !('requesterArchivedByUid' in request.resource.data)
                      || request.resource.data.requesterArchivedByUid == resource.data.requesterArchivedByUid
                    );

      // Atualização B: arquivamento de reprovada pelo próprio solicitante
      allow update: if request.auth != null
                    && resource.data.requesterUid == request.auth.uid
                    && resource.data.status == 'rejected'
                    && (
                      !('requesterArchivedAt' in resource.data)
                      || resource.data.requesterArchivedAt == null
                    )
                    && request.resource.data.requesterUid == resource.data.requesterUid
                    && request.resource.data.requesterName == resource.data.requesterName
                    && request.resource.data.startDate == resource.data.startDate
                    && request.resource.data.endDate == resource.data.endDate
                    && request.resource.data.businessDays == resource.data.businessDays
                    && request.resource.data.status == resource.data.status
                    && request.resource.data.createdAt == resource.data.createdAt
                    && request.resource.data.requesterArchivedAt is string
                    && request.resource.data.requesterArchivedByUid == request.auth.uid
                    && request.resource.data.updatedAt is string;

      // Exclusão: somente super admin
      allow delete: if isSuperAdmin();
    }

    match /polls/{pollId}/{document=**} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if isSuperAdmin();
    }

    match /idleFabMessages/{document=**} {
      allow read: if request.auth != null;
      allow write: if isSuperAdmin();
    }

    // =========================
    // workflows
    // =========================
    match /workflows/{document=**} {
      allow read, write: if true;
    }

    // =========================
    // workflowDefinitions / workflowAreas
    // =========================
    match /workflowDefinitions/{document=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /workflowAreas/{document=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // =========================
    // counters
    // =========================
    match /counters/{document=**} {
      allow read, write: if true;
    }

    // =========================
    // audit_logs
    // =========================
    match /audit_logs/{logId} {
      allow create: if request.auth != null;
      allow read, update, delete: if isSuperAdmin();
    }

    // =========================
    // fabMessages
    // =========================
    match /fabMessages/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if isSuperAdmin();
    }

    // =========================
    // meeting_analyses
    // =========================
    match /meeting_analyses/{analysisId} {
      allow read: if request.auth != null &&
                     resource.data.user_email == request.auth.token.email;
      allow write: if isSuperAdmin();
    }
  }
}
